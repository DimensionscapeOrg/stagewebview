<?xml version="1.0" encoding="utf-8"?>
<project>
	<meta
		title="StageWebView"
		package="com.dimensionscape.stagewebview"
		version="1.0.0"
		company="Dimensionscape" />

	<app main="Main" file="stagewebview" path="bin" />

	<window width="1280" height="720" fps="60" background="#FFFFFF" />
	<window if="cpp" orientation="landscape" vsync="false" antialiasing="0" />

	<source path="src" />
	<source path="src-openfl" />
	<source path="samples/basic/src" />
	<haxeflag name="--macro" value="stagewebview._internal.ExtraParamsMacro.include()" />

	<haxelib name="openfl" />

	<!-- Runtime dependencies for the vendored WebView2 backend (x64 only) -->
	<assets path="ndll/Windows64/stagewebview.hdll" rename="stagewebview.hdll" unless="HXCPP_M32" if="hl" />
	<assets path="lib/windows/x64" rename="" exclude="WebView2Loader.dll.lib" unless="HXCPP_M32" if="windows" />
	<assets path="lib/windows/EBWebView/x64" rename="EBWebView/x64" unless="HXCPP_M32" if="windows" />
</project>
