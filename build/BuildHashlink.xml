<xml>

	<set name="HASHLINK_INCLUDE" value="" unless="HASHLINK_INCLUDE" />
	<set name="LIBHL_PATH" value="" unless="LIBHL_PATH" />
	<set name="LIBHL_DLL_DIR" value="" unless="LIBHL_DLL_DIR" />
	<set name="OUTPUT_DIR" value="${this_dir}/../ndll/Windows64" unless="OUTPUT_DIR" />
	<set name="STAGEWEBVIEW_OBJ_DIR" value="${this_dir}/../build/obj" unless="STAGEWEBVIEW_OBJ_DIR" />

	<section if="windows">
		<compiler id="MSVC">
			<objdir value="${STAGEWEBVIEW_OBJ_DIR}/msvc${MSVC_VER}${OBJEXT}${OBJCACHE}${XPOBJ}" unless="winrt" />
			<objdir value="${STAGEWEBVIEW_OBJ_DIR}/msvc${MSVC_VER}-rt${OBJEXT}${OBJCACHE}${XPOBJ}" if="winrt" />
			<objdir value="${STAGEWEBVIEW_OBJ_DIR}/msvc${MSVC_VER}-arm${OBJEXT}${OBJCACHE}${XPOBJ}" if="HXCPP_ARM64" />
		</compiler>

		<linker id="dll">
			<libdir name="${STAGEWEBVIEW_OBJ_DIR}/lib" />
		</linker>

		<files id="stagewebview">
			<compilerflag value="-I${this_dir}/.." />
			<compilerflag value="-I${this_dir}/../lib/windows" />
			<compilerflag value="-I${HASHLINK_INCLUDE}" />
			<compilerflag value="-DINT_MAX=2147483647" />

			<file name="${this_dir}/../lib/WebViewBackend.cpp" />
			<file name="${this_dir}/../lib/WebViewHashLink.cpp" />
			<file name="${this_dir}/../lib/WindowBackend.cpp" />
			<file name="${this_dir}/../lib/WindowHashLink.cpp" />
		</files>
	</section>

	<target id="stagewebview" output="stagewebview" tool="linker" toolid="dll">
		<outdir name="${OUTPUT_DIR}" />
		<ext value=".hdll" />
		<files id="stagewebview" />

			<section if="windows" unless="HXCPP_M32">
				<copyFile name="WebView2Loader.dll" from="${this_dir}/../lib/windows/x64" toolId="dll" overwrite="true" />
			</section>

		<section if="LIBHL_DLL_DIR">
			<copyFile name="libhl.dll" from="${LIBHL_DLL_DIR}" toolId="dll" overwrite="true" />
		</section>

			<section if="windows">
				<lib name="-libpath:${LIBHL_PATH}" />
				<lib name="libhl.lib" />
				<lib name="${this_dir}/../lib/windows/x64/WebView2Loader.dll.lib" unless="HXCPP_M32" />
				<lib name="Advapi32.lib" />
			<lib name="Ole32.lib" />
			<lib name="Shell32.lib" />
			<lib name="Shlwapi.lib" />
			<lib name="User32.lib" />
			<lib name="Version.lib" />
			<lib name="Gdi32.lib" />
		</section>
	</target>

	<target id="default">
		<target id="stagewebview" />
	</target>

</xml>
